    "version": "0.2.0",
    "configurations": [
        {
            "name": "Mit Persistenz",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}",
            "env": {
                "HTTPSPORT": "3443",
                "PORT": "3000",
                "PERSISTENCE": "ONDISK",
            },
        },
        {
            "name": "In Memory",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}",
            "env": {
                "HTTPSPORT": "3443",
                "PORT": "3000",
                "PERSISTENCE": "INMEMORY",
            },
        },
    ]
}